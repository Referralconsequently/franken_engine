  "interference_rules": [
    {
      "rule_id": "module_graph_cache_contention",
      "primary_family": "module_graphs",
      "concurrent_family": "npm_cohorts",
      "shared_resources": [
        "artifact_cache",
        "module_cache",
        "worker_threads"
      ],
      "decomposition_label": "cache_revalidation_vs_transitive_resolution",
      "explanation": "Module-graph and npm cohort cells share cache and worker resources, so wins must be decomposed instead of merged into a single macro average."
    },
    {
      "rule_id": "async_scheduler_contention",
      "primary_family": "async",
      "concurrent_family": "mixed_package",
      "shared_resources": [
        "scheduler_queue",
        "worker_threads"
      ],
      "decomposition_label": "promise_queue_vs_cross_package_background_work",
      "explanation": "Async cells can look better in isolation than they do inside a real mixed board when queue and worker budgets are shared."
    },
    {
      "rule_id": "react_bundle_contention",
      "primary_family": "react_ssr",
      "concurrent_family": "react_client",
      "shared_resources": [
        "artifact_cache",
        "scheduler_queue",
        "memory_bandwidth"
      ],
      "decomposition_label": "ssr_streaming_vs_hydration_handoff",
      "explanation": "SSR and client hydration reuse bundle artifacts and compete on the same queue/memory envelope; both surfaces must stay explicit."
    },
    {
      "rule_id": "mixed_board_frontend_contention",
      "primary_family": "mixed_package",
      "concurrent_family": "module_graphs",
      "shared_resources": [
        "frontend_cpu",
        "artifact_cache",
        "worker_threads"
      ],
      "decomposition_label": "frontend_parse_compile_vs_transitive_module_activation",
      "explanation": "Cross-family boards must record whether wins come from frontend speed, cache reuse, or simply moving contention elsewhere."
    },
    {
      "rule_id": "tail_latency_scheduler_pressure",
      "primary_family": "tail_latency",
      "concurrent_family": "mixed_package",
      "shared_resources": [
        "scheduler_queue",
        "worker_threads",
        "memory_bandwidth"
      ],
      "decomposition_label": "queue_delay_gc_pause_render_tail_split",
      "explanation": "Tail cells require stage-aware decomposition so p99 regressions cannot hide behind average throughput gains."
    },
    {
      "rule_id": "memory_pressure_cross_family",
      "primary_family": "memory_pressure",
      "concurrent_family": "react_ssr",
      "shared_resources": [
        "memory_bandwidth",
        "artifact_cache"
      ],
      "decomposition_label": "bundle_residency_vs_render_peak",
      "explanation": "Memory disqualifiers must remain attributable to the family interactions that created them, not just to the final board outcome."
    }
  ],
  "tail_decomposition_axes": [
    {
      "axis": "parse_ns",
      "stage": "frontend_parse",
      "description": "Frontend parse contribution to p95/p99 tail outcomes."
    },
    {
      "axis": "compile_ns",
      "stage": "frontend_compile",
      "description": "Compile/lowering contribution to tail outcomes."
    },
    {
      "axis": "module_load_ns",
      "stage": "module_activation",
      "description": "Transitive module activation and loader contribution to the tail."
    },
    {
      "axis": "queue_delay_ns",
      "stage": "scheduler_queue",
      "description": "Time spent waiting in shared scheduler or worker queues."
    },
    {
      "axis": "render_ns",
      "stage": "react_render",
      "description": "Render/commit or SSR render contribution to the tail."
    },
    {
      "axis": "hydration_ns",
      "stage": "react_hydration",
      "description": "Hydration and client handoff contribution to the tail."
    },
    {
      "axis": "gc_pause_ns",
      "stage": "memory_reclamation",
      "description": "GC or reclamation pause contribution to high-percentile latency."
    }
  ]
}
