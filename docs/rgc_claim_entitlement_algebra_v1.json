  "disqualifier_rules": {
    "schema_version": "franken-engine.rgc-disqualifier-rules.v1",
    "precedence_order": [
      "rule.active_counterexample",
      "rule.unsupported_surface_promoted",
      "rule.stale_evidence",
      "rule.missing_platform_verification",
      "rule.missing_user_guidance",
      "rule.tail_or_memory_regression",
      "rule.docs_help_contradiction"
    ],
    "rules": [
      {
        "rule_id": "rule.active_counterexample",
        "precedence": 0,
        "evidence_kind": "counterexample_ledger",
        "condition": "counterexample_status == active",
        "target_atoms": [
          "claim.frankenctl.compile.shipped",
          "claim.frankenctl.run.shipped",
          "claim.frankenctl.doctor.shipped",
          "claim.v8.scoped_observed.publishable",
          "claim.rollout.doctor_guidance.shipped",
          "claim.ga.exit_evidence.gated"
        ],
        "verdict": "forbid",
        "remediation": "Resolve or classify the active counterexample before restoring stronger language."
      },
      {
        "rule_id": "rule.unsupported_surface_promoted",
        "precedence": 1,
        "evidence_kind": "support_surface_contract",
        "condition": "support_status in [unsupported, deferred] but public wording uses shipped language",
        "target_atoms": [
          "claim.react.compile.target",
          "claim.react.ssr.unsupported",
          "claim.support.unsupported_surface.visible"
        ],
        "verdict": "downgrade_to_target",
        "remediation": "Downgrade to target-only or unsupported-surface wording and restore diagnostics."
      },
      {
        "rule_id": "rule.stale_evidence",
        "precedence": 2,
        "evidence_kind": "artifact_ttl",
        "condition": "artifact_age_hours > declared_ttl_hours",
        "target_atoms": [
          "claim.frankenctl.compile.shipped",
          "claim.frankenctl.run.shipped",
          "claim.frankenctl.doctor.shipped",
          "claim.frankenctl.verify.shipped",
          "claim.frankenctl.benchmark.shipped",
          "claim.frankenctl.replay.shipped",
          "claim.v8.scoped_observed.publishable",
          "claim.rollout.doctor_guidance.shipped",
          "claim.ga.exit_evidence.gated"
        ],
        "verdict": "downgrade_to_scoped",
        "remediation": "Refresh the expired evidence bundle before using present-tense shipped or scoped-observed language."
      },
      {
        "rule_id": "rule.missing_platform_verification",
        "precedence": 3,
        "evidence_kind": "platform_verification_matrix",
        "condition": "required target platform lacks a green verification row",
        "target_atoms": [
          "claim.rollout.doctor_guidance.shipped",
          "claim.ga.exit_evidence.gated"
        ],
        "verdict": "downgrade_to_target",
        "remediation": "Treat the claim as incomplete until the missing platform evidence exists."
      },
      {
        "rule_id": "rule.missing_user_guidance",
        "precedence": 4,
        "evidence_kind": "support_surface_contract",
        "condition": "unsupported or deferred surface lacks user-visible diagnostics or remediation guidance",
        "target_atoms": [
          "claim.react.ssr.unsupported",
          "claim.support.unsupported_surface.visible"
        ],
        "verdict": "require_operator_guidance",
        "remediation": "Publish explicit remediation guidance before allowing unsupported-surface messaging."
      },
      {
        "rule_id": "rule.tail_or_memory_regression",
        "precedence": 5,
        "evidence_kind": "v8_supremacy_contract",
        "condition": "tail or memory side constraints are non-green",
        "target_atoms": [
          "claim.v8.universal_dominance.frontier",
          "claim.v8.scoped_observed.publishable"
        ],
        "verdict": "downgrade_to_scoped",
        "remediation": "Shrink the scope or fix the side-constraint regressions before publishing stronger performance language."
      },
      {
        "rule_id": "rule.docs_help_contradiction",
        "precedence": 6,
        "evidence_kind": "docs_help_surface_audit",
        "condition": "README/help smoke contradicts the claimed shipped command surface",
        "target_atoms": [
          "claim.frankenctl.compile.shipped",
          "claim.frankenctl.run.shipped",
          "claim.frankenctl.doctor.shipped",
          "claim.frankenctl.verify.shipped",
          "claim.frankenctl.benchmark.shipped",
          "claim.frankenctl.replay.shipped"
        ],
        "verdict": "downgrade_to_target",
        "remediation": "Narrow the public wording or repair the shipped behavior so docs and implementation agree."
      }
    ]
  },
